# ── Airflow metadata DB ───────────────────────────────────────────────────────
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=
AIRFLOW_DB_NAME=airflow

# ── Market data DB ────────────────────────────────────────────────────────────
MARKET_DB_USER=market
MARKET_DB_PASSWORD=
MARKET_DB_NAME=market

# ── Airflow security ──────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_KEY=

# ── CoinGecko ─────────────────────────────────────────────────────────────────
# Free demo key from coingecko.com — sent as X-CG-Demo-Api-Key header
COINGECKO_API_KEY=

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
